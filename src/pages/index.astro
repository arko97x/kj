      </div>
    </main>

    <!-- Screen 2: Letters -->
    <div id="screen-2" style="display: none;">
      <main class="letters-page">
        <div class="scatter">
          {rendered.map(({ entry }) => (
            <Envelope
              name={entry.data.name}
              stamp={entry.data.stamp}
              kjStamp={entry.data.kjStamp}
              rotation={entry.data.rotation}
              offsetX={entry.data.offsetX}
              offsetY={entry.data.offsetY}
              slug={entry.id}
            />
          ))}
        </div>
      </main>
    </div>

    {rendered.map(({ entry, Content, font }) => (
      <template data-letter={entry.id} data-font={font}>
        <Content />
      </template>
    ))}

    <div class="letter-backdrop"></div>
    <div class="letter-sheet" role="dialog" aria-hidden="true">
      <button class="sheet-close" type="button" aria-label="Close letter">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div class="sheet-scroll">
        <p class="sheet-from-label">a letter from</p>
        <h2 class="sheet-sender"></h2>
        <hr class="sheet-rule" />
        <div class="sheet-body"></div>
      </div>
    </div>

    <!-- Dot grid -->
    <script>
      const canvas = document.getElementById("dot-grid") as HTMLCanvasElement;
      const ctx = canvas.getContext("2d")!;

      const SPACING = 16;
      const DOT_RADIUS = 1;
      const INFLUENCE_RADIUS = 140;
      const PUSH_STRENGTH = 12;
      const EASE_BACK = 0.15;
      const DOT_COLOR = "#a6a09a";

      interface Dot {
        ox: number;
        oy: number;
        x: number;
        y: number;
      }

      let dots: Dot[] = [];
      let mouse = { x: -9999, y: -9999 };
      let dpr = window.devicePixelRatio || 1;

      function initDots() {
        dots = [];
        const cols = Math.ceil(canvas.width / dpr / SPACING) + 1;
        const rows = Math.ceil(canvas.height / dpr / SPACING) + 1;
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            dots.push({
              ox: c * SPACING,
              oy: r * SPACING,
              x: c * SPACING,
              y: r * SPACING,
            });
          }
        }
      }

      function resize() {
        dpr = window.devicePixelRatio || 1;
        canvas.width = window.innerWidth * dpr;
        canvas.height = window.innerHeight * dpr;
        canvas.style.width = window.innerWidth + "px";
        canvas.style.height = window.innerHeight + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        initDots();
      }

      function animate() {
        ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);
        ctx.fillStyle = DOT_COLOR;
        ctx.beginPath();

        for (const dot of dots) {
          const dx = dot.ox - mouse.x;
          const dy = dot.oy - mouse.y;
          const distSq = dx * dx + dy * dy;
          const influenceSq = INFLUENCE_RADIUS * INFLUENCE_RADIUS;

          let targetX = dot.ox;
          let targetY = dot.oy;

          if (distSq < influenceSq && distSq > 0) {
            const dist = Math.sqrt(distSq);
            const t = 1 - dist / INFLUENCE_RADIUS;
            const push = t * t * PUSH_STRENGTH;
            targetX = dot.ox + (dx / dist) * push;
            targetY = dot.oy + (dy / dist) * push;
          }

          dot.x += (targetX - dot.x) * EASE_BACK;
          dot.y += (targetY - dot.y) * EASE_BACK;

          ctx.moveTo(dot.x + DOT_RADIUS, dot.y);
          ctx.arc(dot.x, dot.y, DOT_RADIUS, 0, Math.PI * 2);
        }

        ctx.fill();
        requestAnimationFrame(animate);
      }

      window.addEventListener("resize", resize);
      window.addEventListener("mousemove", (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
      });
      window.addEventListener("mouseleave", () => {
        mouse.x = -9999;
        mouse.y = -9999;
      });

      resize();
      animate();
    </script>

    <!-- Polaroid tilt + glimmer -->
    <script>
      const polaroid = document.getElementById("polaroid") as HTMLElement;
      const glimmer = document.getElementById("polaroid-glimmer") as HTMLElement;
      const polaroidEntrance = document.getElementById("polaroid-entrance") as HTMLElement;

      polaroidEntrance.addEventListener("animationend", () => {
        polaroidEntrance.style.animation = "none";
        polaroidEntrance.style.transform = "";
        polaroidEntrance.style.opacity = "";
      }, { once: true });

      const BASE_ROTATE = -2;
      const MAX_TILT = 12;

      let currentX = BASE_ROTATE;
      let currentY = 0;
      let targetX = BASE_ROTATE;
      let targetY = 0;
      let rafId: number;

      function lerp(a: number, b: number, t: number) {
        return a + (b - a) * t;
      }

      function tick() {
        currentX = lerp(currentX, targetX, 0.18);
        currentY = lerp(currentY, targetY, 0.18);
        polaroid.style.transform = `rotate(${BASE_ROTATE}deg) rotateX(${currentY}deg) rotateY(${currentX}deg)`;
        rafId = requestAnimationFrame(tick);
      }

      window.addEventListener("mousemove", (e) => {
        const rect = polaroid.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = (e.clientX - cx) / window.innerWidth;
        const dy = (e.clientY - cy) / window.innerHeight;
        targetX = dx * MAX_TILT;
        targetY = -dy * MAX_TILT;

        const px = ((e.clientX - rect.left) / rect.width) * 100;
        const py = ((e.clientY - rect.top) / rect.height) * 100;
        glimmer.style.background = `radial-gradient(circle at ${px}% ${py}%, rgba(255,255,255,0.45) 0%, rgba(255,255,255,0.08) 40%, transparent 70%)`;
        glimmer.style.opacity = "1";
      });

      window.addEventListener("mouseleave", () => {
        targetX = 0;
        targetY = 0;
        glimmer.style.opacity = "0";
      });

      tick();
    </script>

    <!-- Paper texture shader (runs eagerly, applies to envelopes in background) -->
    <script>
      import {
        ShaderMount,
        paperTextureFragmentShader,
        getShaderColorFromString,
        getShaderNoiseTexture,
        ShaderFitOptions,
      } from '@paper-design/shaders';

      try {
        const container = document.createElement('div');
        container.style.cssText =
          'position:fixed;top:0;left:0;width:400px;height:276px;opacity:0;pointer-events:none;z-index:-9999;';
        document.body.appendChild(container);

        const noiseTexture = getShaderNoiseTexture();

        const uniforms: Record<string, any> = {
          u_image: '',
          u_colorBack: getShaderColorFromString('#ffffff'),
          u_colorFront: getShaderColorFromString('#f2e7cf'),
          u_contrast: 1,
          u_roughness: 0.99,
          u_fiber: 0.42,
          u_fiberSize: 0.35,
          u_crumples: 0.3,
          u_crumpleSize: 0.13,
          u_folds: 0.65,
          u_foldCount: 5,
          u_fade: 0.35,
          u_drops: 0.07,
          u_seed: 480.8,
          u_fit: ShaderFitOptions.cover,
          u_scale: 0.5,
          u_rotation: 0,
          u_originX: 0.5,
          u_originY: 0.5,
          u_offsetX: 0,
          u_offsetY: 0,
          u_worldWidth: 0,
          u_worldHeight: 0,
        };

        if (noiseTexture) uniforms.u_noiseTexture = noiseTexture;

        const mount = new ShaderMount(
          container,
          paperTextureFragmentShader,
          uniforms,
          undefined,
          0,
        );

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            const canvas = container.querySelector('canvas');
            if (canvas) {
              const dataUrl = canvas.toDataURL('image/png');
              document.querySelectorAll<HTMLElement>('.envelope').forEach((el) => {
                el.style.backgroundImage = `url(${dataUrl})`;
                el.style.backgroundSize = 'cover';
              });
            }
            mount.dispose();
            container.remove();
          });
        });
      } catch {
        // WebGL unavailable — envelopes keep their solid CSS background
      }
    </script>

    <!-- Scatter-in animation (triggered after transition) -->
    <script>
      document.addEventListener('start-scatter', () => {
        const scatter = document.querySelector('.scatter') as HTMLElement;
        const envelopes = [...document.querySelectorAll<HTMLElement>('.envelope')];

        const rect = scatter.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;

        envelopes.forEach((el, i) => {
          const r = el.getBoundingClientRect();
          const dx = cx - (r.left + r.width / 2);
          const dy = cy - (r.top + r.height / 2);

          el.style.setProperty('--dx', `${dx}px`);
          el.style.setProperty('--dy', `${dy}px`);
          el.style.setProperty('--delay', `${i * 70}ms`);
          el.classList.add('animate-in');

          el.addEventListener('animationend', () => {
            el.classList.remove('animate-in');
            el.style.opacity = '1';
            el.style.removeProperty('--dx');
            el.style.removeProperty('--dy');
            el.style.removeProperty('--delay');
          }, { once: true });
        });
      });
    </script>

    <!-- Letter sheet open/close -->
    <script>
      const backdrop = document.querySelector<HTMLElement>('.letter-backdrop')!;
      const sheet = document.querySelector<HTMLElement>('.letter-sheet')!;
      const sheetScroll = sheet.querySelector<HTMLElement>('.sheet-scroll')!;
      const sheetSender = sheet.querySelector<HTMLElement>('.sheet-sender')!;
      const sheetBody = sheet.querySelector<HTMLElement>('.sheet-body')!;
      const closeBtn = sheet.querySelector<HTMLElement>('.sheet-close')!;

      let activeEnvelope: HTMLElement | null = null;
      let activeEnvAnim: Animation | null = null;
      let savedStartTransform = '';
      let savedEndTransform = '';
      let isOpen = false;
      let isAnimating = false;

      function openSheet(envelope: HTMLElement) {
        if (isOpen || isAnimating) return;
        isAnimating = true;
        activeEnvelope = envelope;

        const sender = envelope.dataset.sender || '';
        const slug = envelope.dataset.slug || '';
        sheetSender.textContent = sender;

        const tpl = document.querySelector<HTMLTemplateElement>(`template[data-letter="${slug}"]`);
        if (tpl) {
          sheetBody.innerHTML = '';
          sheetBody.appendChild(tpl.content.cloneNode(true));
          sheetBody.style.fontFamily = tpl.dataset.font || '';
        }

        sheet.getAnimations().forEach(a => a.cancel());
        sheetScroll.getAnimations().forEach(a => a.cancel());
        backdrop.getAnimations().forEach(a => a.cancel());
        sheet.removeAttribute('style');
        sheetScroll.removeAttribute('style');

        const envRect = envelope.getBoundingClientRect();
        const vw = window.innerWidth;
        const vh = window.innerHeight;

        backdrop.style.display = 'block';
        backdrop.animate(
          [{ opacity: 0 }, { opacity: 1 }],
          { duration: 380, fill: 'forwards', easing: 'ease-out' }
        );

        document.body.classList.add('sheet-open');

        envelope.style.zIndex = '501';
        const envCx = envRect.left + envRect.width / 2;
        const envCy = envRect.top + envRect.height / 2;
        const matrix = new DOMMatrix(getComputedStyle(envelope).transform);
        const baseCx = envCx - matrix.e;
        const baseCy = envCy - matrix.f;
        const flyTx = vw / 2 - baseCx;
        const flyTy = vh - baseCy;

        const cs = getComputedStyle(envelope);
        const cssR = cs.getPropertyValue('--r').trim() || '0deg';
        const cssTx = cs.getPropertyValue('--tx').trim() || '0px';
        const cssTy = cs.getPropertyValue('--ty').trim() || '0px';
        savedStartTransform = `rotate(${cssR}) translate(${cssTx}, ${cssTy})`;
        savedEndTransform = `translate(${flyTx}px, ${flyTy}px) perspective(800px) rotateY(180deg) scale(0.25)`;

        activeEnvAnim = envelope.animate([
          { transform: `${savedStartTransform} perspective(800px) rotateY(0deg)`, opacity: 1 },
          { transform: savedEndTransform, opacity: 0 },
        ], {
          duration: 500,
          easing: 'cubic-bezier(0.4, 0, 0.2, 1)',
          fill: 'forwards',
        });

        const isPhone = vw <= 480;
        const sheetW = Math.min(isPhone ? vw : vw - 32, 700);
        const sheetH = Math.min(vh * (isPhone ? 0.93 : 0.92), 860);
        const endTop = vh - sheetH;
        const endLeft = (vw - sheetW) / 2;
        const startW = envRect.width * 0.3;
        const startLeft = (vw - startW) / 2;

        setTimeout(() => {
          sheet.style.display = 'flex';
          sheetScroll.style.opacity = '0';

          const sheetAnim = sheet.animate([
            {
              top: `${vh}px`,
              left: `${startLeft}px`,
              width: `${startW}px`,
              height: '0px',
              borderRadius: '8px 8px 0 0',
              opacity: '0.85',
            },
            {
              top: `${endTop}px`,
              left: `${endLeft}px`,
              width: `${sheetW}px`,
              height: `${sheetH}px`,
              borderRadius: '18px 18px 0 0',
              opacity: '1',
            },
          ], {
            duration: 500,
            easing: 'cubic-bezier(0.22, 0.61, 0.36, 1)',
            fill: 'forwards',
          });

          sheetAnim.onfinish = () => {
            sheet.style.top = `${endTop}px`;
            sheet.style.left = `${endLeft}px`;
            sheet.style.width = `${sheetW}px`;
            sheet.style.height = `${sheetH}px`;
            sheet.style.borderRadius = '18px 18px 0 0';
            sheet.style.opacity = '1';

            sheetScroll.animate(
              [
                { opacity: 0, transform: 'translateY(16px)' },
                { opacity: 1, transform: 'translateY(0)' },
              ],
              { duration: 280, fill: 'forwards', easing: 'ease-out' }
            ).onfinish = () => {
              sheetScroll.style.opacity = '1';
              sheetScroll.style.transform = '';
              isOpen = true;
              isAnimating = false;
              sheet.setAttribute('aria-hidden', 'false');
            };
          };
        }, 280);
      }

      function closeSheet() {
        if (!isOpen || isAnimating) return;
        isAnimating = true;
        isOpen = false;

        sheetScroll.animate(
          [{ opacity: 1 }, { opacity: 0 }],
          { duration: 150, fill: 'forwards' }
        );

        const closeAnim = sheet.animate([
          { transform: 'translateY(0)', opacity: 1 },
          { transform: `translateY(${window.innerHeight}px)`, opacity: 0 },
        ], {
          duration: 400,
          easing: 'cubic-bezier(0.55, 0.06, 0.68, 0.19)',
          fill: 'forwards',
        });
        closeAnim.onfinish = () => {
          closeAnim.cancel();
          sheet.removeAttribute('style');
          sheetScroll.removeAttribute('style');
          sheet.setAttribute('aria-hidden', 'true');
        };

        backdrop.animate(
          [{ opacity: 1 }, { opacity: 0 }],
          { duration: 350, fill: 'forwards', easing: 'ease-in' }
        ).onfinish = () => {
          backdrop.style.display = 'none';
        };

        document.body.classList.remove('sheet-open');

        if (activeEnvelope) {
          const env = activeEnvelope;
          if (activeEnvAnim) {
            activeEnvAnim.cancel();
            activeEnvAnim = null;
          }
          env.style.opacity = '0';

          setTimeout(() => {
            const returnAnim = env.animate([
              { transform: savedEndTransform, opacity: 0 },
              { transform: `${savedStartTransform} perspective(800px) rotateY(0deg)`, opacity: 1, offset: 0.85 },
              { transform: savedStartTransform, opacity: 1 },
            ], {
              duration: 550,
              easing: 'cubic-bezier(0.22, 0.61, 0.36, 1)',
              fill: 'forwards',
            });
            returnAnim.onfinish = () => {
              returnAnim.cancel();
              env.style.opacity = '1';
              env.style.zIndex = '';
              isAnimating = false;
            };
          }, 180);
          activeEnvelope = null;
        } else {
          isAnimating = false;
        }
      }

      document.querySelectorAll<HTMLElement>('.envelope').forEach(el => {
        el.addEventListener('click', () => {
          if (el.classList.contains('animate-in')) return;
          openSheet(el);
        });
      });

      backdrop.addEventListener('click', closeSheet);
      closeBtn.addEventListener('click', closeSheet);

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) closeSheet();
      });
    </script>

    <!-- Button click: transition from landing to letters -->
    <script>
      const loveBtn = document.getElementById("love-btn") as HTMLButtonElement;
      const screen1 = document.getElementById("screen-1") as HTMLElement;
      const screen2 = document.getElementById("screen-2") as HTMLElement;
      const dotGrid = document.getElementById("dot-grid") as HTMLCanvasElement;

      let transitioned = false;

      loveBtn.addEventListener("click", () => {
        if (transitioned) return;
        transitioned = true;

        const exitTargets = [
          document.getElementById("btn-entrance")!,
          document.getElementById("text-happy")!,
          document.getElementById("text-name")!,
          document.getElementById("text-dearest")!,
          document.getElementById("polaroid-entrance")!,
        ];

        const STAGGER = 70;
        const DURATION = 380;

        let lastAnim!: Animation;
        exitTargets.forEach((el, i) => {
          lastAnim = el.animate([
            { transform: 'scale(1)', opacity: 1, easing: 'ease-out' },
            { transform: 'scale(1.12)', opacity: 1, offset: 0.28, easing: 'cubic-bezier(0.55, 0, 1, 0.45)' },
            { transform: 'scale(0)', opacity: 0 },
          ], {
            duration: DURATION,
            delay: i * STAGGER,
            fill: 'forwards',
          });
        });

        lastAnim.onfinish = () => {
          screen1.style.display = "none";
          screen2.style.display = "block";
          document.body.style.overflowY = "auto";

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              document.dispatchEvent(new CustomEvent('start-scatter'));
            });
          });
        };
      });
    </script>
  </body>
</html>
