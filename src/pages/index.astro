---
import "../styles/global.css";
---

<style>
  .love-btn {
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #fffbf5;
    background: #5a189a;
    border: none;
    border-radius: 14px;
    padding: 13px 32px;
    cursor: pointer;
    box-shadow: 0 5px 0 0 #1a0030;
    transform: translateY(0);
    user-select: none;
    outline: none;
    position: relative;
  }

  @media (min-width: 768px) {
    .love-btn {
      font-size: 1.05rem;
    }
  }

  .love-btn:hover {
    background: #6d28a0;
    transform: translateY(-2px);
    box-shadow: 0 7px 0 0 #1a0030;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .love-btn.pressing {
    animation: btn-press 0.35s ease forwards;
    pointer-events: none;
  }

  @keyframes btn-press {
    0%   { transform: translateY(0px);  box-shadow: 0 5px 0 0 #1a0030; }
    30%  { transform: translateY(5px);  box-shadow: 0 0px 0 0 #1a0030; }
    70%  { transform: translateY(-2px); box-shadow: 0 7px 0 0 #1a0030; }
    100% { transform: translateY(0px);  box-shadow: 0 5px 0 0 #1a0030; }
  }

  @keyframes entrance-pop {
    from { transform: scale(0.65); opacity: 0; }
    to   { transform: scale(1);    opacity: 1; }
  }

  @keyframes entrance-fade-up {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #polaroid-entrance {
    animation: entrance-pop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    transform-style: preserve-3d;
  }

  #text-dearest {
    animation: entrance-fade-up 0.4s ease both;
    animation-delay: 0.15s;
  }

  #text-name {
    animation: entrance-fade-up 0.4s ease both;
    animation-delay: 0.35s;
  }

  #text-happy {
    animation: entrance-fade-up 0.4s ease both;
    animation-delay: 0.45s;
  }

  #btn-entrance {
    animation: entrance-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: 0.6s;
    display: inline-block;
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>KJ, Happy Birthday!</title>
  </head>
  <body>
    <canvas id="dot-grid"></canvas>

    <main id="screen-1" class="relative z-10 flex items-center justify-center min-h-screen px-8 py-16" style="transition: opacity 0.5s ease;">
      <div class="flex flex-col items-center gap-10 max-w-3xl w-full">
        <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-center w-full">
          <!-- Polaroid -->
          <div class="flex-1 flex justify-center" style="perspective: 800px;">
            <div id="polaroid-entrance">
            <div
              id="polaroid"
              class="bg-white p-3 pb-13 rounded-lg shadow-xl inline-block relative overflow-hidden border border-gray-200"
              style="transform: rotate(-2deg); will-change: transform; transition: transform 0.1s ease-out;"
            >
              <img
                src="/images/kj-landing.avif"
                alt="KJ"
                class="w-56 md:w-64 lg:w-72 block object-cover rounded-sm"
                style="aspect-ratio: 3/4;"
              />
              <div
                id="polaroid-glimmer"
                class="absolute inset-0 rounded-lg pointer-events-none"
                style="opacity: 0; transition: opacity 0.3s ease;"
              >              </div>
            </div>
            </div>
          </div>

          <!-- Text -->
          <div class="flex-1 flex flex-col gap-2 text-center items-center">
            <p id="text-dearest" class="text-stone-500 text-2xl tracking-wide">Dearest</p>
            <p id="text-name" class="text-3xl md:text-4xl max-w-full md:max-w-[75%] font-medium leading-tighter" style="color: #5a189a;">
              Kart / Katz / KatyK / KJ,
            </p>
            <p id="text-happy" class="text-stone-700 text-4xl md:text-5xl font-medium mt-0 tracking-tight">
              Happy Budday!
            </p>
            <div id="btn-entrance" class="mt-9">
              <button id="love-btn" class="love-btn">We love you 3000</button>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Screen 2 -->
    <section
      id="screen-2"
      class="fixed inset-0 z-10 flex items-center justify-center px-8 py-16 pointer-events-none"
      style="opacity: 0; transition: opacity 0.5s ease;"
    >
      <div class="flex flex-col items-center gap-6 max-w-2xl w-full text-center">
        <p class="text-stone-500 text-xl tracking-wide">more to come here</p>
      </div>
    </section>

    <script>
      const canvas = document.getElementById("dot-grid") as HTMLCanvasElement;
      const ctx = canvas.getContext("2d")!;

      const SPACING = 16;
      const DOT_RADIUS = 1;
      const INFLUENCE_RADIUS = 140;
      const PUSH_STRENGTH = 12;
      const EASE_BACK = 0.15;
      const DOT_COLOR = "#a6a09a";

      interface Dot {
        ox: number;
        oy: number;
        x: number;
        y: number;
      }

      let dots: Dot[] = [];
      let mouse = { x: -9999, y: -9999 };
      let dpr = window.devicePixelRatio || 1;

      function initDots() {
        dots = [];
        const cols = Math.ceil(canvas.width / dpr / SPACING) + 1;
        const rows = Math.ceil(canvas.height / dpr / SPACING) + 1;
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            dots.push({
              ox: c * SPACING,
              oy: r * SPACING,
              x: c * SPACING,
              y: r * SPACING,
            });
          }
        }
      }

      function resize() {
        dpr = window.devicePixelRatio || 1;
        canvas.width = window.innerWidth * dpr;
        canvas.height = window.innerHeight * dpr;
        canvas.style.width = window.innerWidth + "px";
        canvas.style.height = window.innerHeight + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        initDots();
      }

      function animate() {
        ctx.clearRect(0, 0, canvas.width / dpr, canvas.height / dpr);
        ctx.fillStyle = DOT_COLOR;
        ctx.beginPath();

        for (const dot of dots) {
          const dx = dot.ox - mouse.x;
          const dy = dot.oy - mouse.y;
          const distSq = dx * dx + dy * dy;
          const influenceSq = INFLUENCE_RADIUS * INFLUENCE_RADIUS;

          let targetX = dot.ox;
          let targetY = dot.oy;

          if (distSq < influenceSq && distSq > 0) {
            const dist = Math.sqrt(distSq);
            const t = 1 - dist / INFLUENCE_RADIUS;
            const push = t * t * PUSH_STRENGTH;
            targetX = dot.ox + (dx / dist) * push;
            targetY = dot.oy + (dy / dist) * push;
          }

          dot.x += (targetX - dot.x) * EASE_BACK;
          dot.y += (targetY - dot.y) * EASE_BACK;

          ctx.moveTo(dot.x + DOT_RADIUS, dot.y);
          ctx.arc(dot.x, dot.y, DOT_RADIUS, 0, Math.PI * 2);
        }

        ctx.fill();
        requestAnimationFrame(animate);
      }

      window.addEventListener("resize", resize);
      window.addEventListener("mousemove", (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
      });
      window.addEventListener("mouseleave", () => {
        mouse.x = -9999;
        mouse.y = -9999;
      });

      resize();
      animate();
    </script>

    <script>
      const polaroid = document.getElementById("polaroid") as HTMLElement;
      const glimmer = document.getElementById("polaroid-glimmer") as HTMLElement;
      const polaroidEntrance = document.getElementById("polaroid-entrance") as HTMLElement;

      polaroidEntrance.addEventListener("animationend", () => {
        polaroidEntrance.style.animation = "none";
        polaroidEntrance.style.transform = "";
        polaroidEntrance.style.opacity = "";
      }, { once: true });

      const BASE_ROTATE = -2;
      const MAX_TILT = 12;

      let currentX = BASE_ROTATE;
      let currentY = 0;
      let targetX = BASE_ROTATE;
      let targetY = 0;
      let rafId: number;

      function lerp(a: number, b: number, t: number) {
        return a + (b - a) * t;
      }

      function tick() {
        currentX = lerp(currentX, targetX, 0.18);
        currentY = lerp(currentY, targetY, 0.18);
        polaroid.style.transform = `rotate(${BASE_ROTATE}deg) rotateX(${currentY}deg) rotateY(${currentX}deg)`;
        rafId = requestAnimationFrame(tick);
      }

      window.addEventListener("mousemove", (e) => {
        const rect = polaroid.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const dx = (e.clientX - cx) / window.innerWidth;
        const dy = (e.clientY - cy) / window.innerHeight;
        targetX = dx * MAX_TILT;
        targetY = -dy * MAX_TILT;

        // glimmer: map mouse position within polaroid to a highlight spot
        const px = ((e.clientX - rect.left) / rect.width) * 100;
        const py = ((e.clientY - rect.top) / rect.height) * 100;
        glimmer.style.background = `radial-gradient(circle at ${px}% ${py}%, rgba(255,255,255,0.45) 0%, rgba(255,255,255,0.08) 40%, transparent 70%)`;
        glimmer.style.opacity = "1";
      });

      window.addEventListener("mouseleave", () => {
        targetX = 0;
        targetY = 0;
        glimmer.style.opacity = "0";
      });

      tick();
    </script>
    <script>
      const loveBtn = document.getElementById("love-btn") as HTMLButtonElement;
      const screen1 = document.getElementById("screen-1") as HTMLElement;
      const screen2 = document.getElementById("screen-2") as HTMLElement;

      loveBtn.addEventListener("click", () => {
        if (loveBtn.classList.contains("pressing")) return;
        loveBtn.classList.add("pressing");

        loveBtn.addEventListener(
          "animationend",
          () => {
            loveBtn.classList.remove("pressing");

            screen1.style.opacity = "0";
            screen1.style.pointerEvents = "none";

            screen2.style.opacity = "1";
            screen2.style.pointerEvents = "auto";
          },
          { once: true }
        );
      });
    </script>
  </body>
</html>
