---
import "../styles/global.css";
import { getCollection, render } from "astro:content";
import Envelope from "../components/Envelope.astro";

const allLetters = (await getCollection("letters")).sort((a, b) => {
  const ao = a.data.order ?? Infinity;
  const bo = b.data.order ?? Infinity;
  return ao - bo;
});

const handwritingFonts = [
  '"Caveat", cursive',
  '"Dawning of a New Day", cursive',
  '"Homemade Apple", cursive',
  '"Single Day", cursive',
];

const rendered = await Promise.all(
  allLetters.map(async (entry, i) => {
    const { Content } = await render(entry);
    const font = handwritingFonts[i % handwritingFonts.length];
    return { entry, Content, font };
  })
);
---

<style>
  .love-btn {
    font-family: inherit;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: #fffbf5;
    background: #5a189a;
    border: none;
    border-radius: 14px;
    padding: 13px 32px;
    cursor: pointer;
    box-shadow: 0 5px 0 0 #1a0030;
    transform: translateY(0);
    user-select: none;
    outline: none;
    position: relative;
  }

  @media (min-width: 768px) {
    .love-btn {
      font-size: 1.05rem;
    }
  }

  .love-btn:hover {
    background: #6d28a0;
    transform: translateY(-2px);
    box-shadow: 0 7px 0 0 #1a0030;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .love-btn.pressing {
    animation: btn-press 0.35s ease forwards;
    pointer-events: none;
  }

  @keyframes btn-press {
    0%   { transform: translateY(0px);  box-shadow: 0 5px 0 0 #1a0030; }
    30%  { transform: translateY(5px);  box-shadow: 0 0px 0 0 #1a0030; }
    70%  { transform: translateY(-2px); box-shadow: 0 7px 0 0 #1a0030; }
    100% { transform: translateY(0px);  box-shadow: 0 5px 0 0 #1a0030; }
  }

  @keyframes entrance-pop {
    from { transform: scale(0.65); opacity: 0; }
    to   { transform: scale(1);    opacity: 1; }
  }

  @keyframes entrance-fade-up {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  #polaroid-entrance {
    animation: entrance-pop 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    transform-style: preserve-3d;
  }

  #text-dearest {
    animation: entrance-fade-up 0.4s ease both;
    animation-delay: 0.15s;
  }

  #text-name {
    animation: entrance-fade-up 0.4s ease both;
    animation-delay: 0.35s;
  }

  #text-happy {
    animation: entrance-fade-up 0.4s ease both;
    animation-delay: 0.45s;
  }

  #btn-entrance {
    animation: entrance-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: 0.6s;
    display: inline-block;
  }
</style>

<style>
  .letters-page {
    min-height: 100vh;
    padding: 72px 24px 96px;
  }

  .scatter {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 28px 36px;
    max-width: 900px;
    margin: 0 auto;
    overflow: visible;
  }

  .scatter :global(.envelope) {
    opacity: 0;
  }

  @media (min-width: 1000px) {
    .scatter {
      max-width: 1140px;
      gap: 40px 16px;
      padding: 0 60px;
    }

    .scatter :global(.envelope) {
      width: 300px;
      padding: 18px;
    }
    .scatter :global(.stamp-area) {
      left: 15px;
      top: 15px;
    }
    .scatter :global(.stamp) {
      width: 116px;
      height: 138px;
      padding: 12px 15px;
    }
    .scatter :global(.address-lines) {
      right: 15px;
      bottom: 95px;
    }
    .scatter :global(.address) {
      bottom: 12px;
      right: 15px;
    }
    .scatter :global(.from-label) {
      font-size: 0.85rem;
    }
    .scatter :global(.sender) {
      font-size: 1.35rem;
    }
    .scatter :global(.kj-stamp) {
      top: 118px;
      left: 103px;
      width: 64px;
    }

    /* Per-card scatter: translate composes on top of each envelope's own transform.
       z-index decreases down the page so earlier rows always sit on top of later rows
       — names at the bottom of each card are never buried under a row-below card.
       Hover always surfaces to the very top. */
    .scatter :global(.envelope:hover) { z-index: 99 !important; }

    .scatter :global(.envelope:nth-child(1))  { translate: -80px   0px; z-index: 15; }
    .scatter :global(.envelope:nth-child(2))  { translate:  30px  56px; z-index: 14; }
    .scatter :global(.envelope:nth-child(3))  { translate: 110px  12px; z-index: 13; }
    .scatter :global(.envelope:nth-child(4))  { translate: -60px  44px; z-index: 12; }
    .scatter :global(.envelope:nth-child(5))  { translate: -10px -16px; z-index: 11; }
    .scatter :global(.envelope:nth-child(6))  { translate: 100px  36px; z-index: 10; }
    .scatter :global(.envelope:nth-child(7))  { translate:-120px  22px; z-index: 9;  }
    .scatter :global(.envelope:nth-child(8))  { translate:  50px  52px; z-index: 8;  }
    .scatter :global(.envelope:nth-child(9))  { translate:  90px -20px; z-index: 7;  }
    .scatter :global(.envelope:nth-child(10)) { translate: -40px  48px; z-index: 6;  }
    .scatter :global(.envelope:nth-child(11)) { translate:  20px   8px; z-index: 5;  }
    .scatter :global(.envelope:nth-child(12)) { translate: 130px  28px; z-index: 4;  }
    .scatter :global(.envelope:nth-child(13)) { translate: -90px  16px; z-index: 3;  }
    .scatter :global(.envelope:nth-child(14)) { translate:  60px  40px; z-index: 2;  }
    .scatter :global(.envelope:nth-child(15)) { translate: -20px  24px; z-index: 1;  }
  }

  .scatter :global(.envelope.animate-in) {
    animation: scatter-in 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) var(--delay, 0s) both;
  }

  @keyframes scatter-in {
    from {
      transform: translate(var(--dx, 0px), var(--dy, 0px)) scale(0.2);
      opacity: 0;
    }
    to {
      transform: rotate(var(--r, 0deg)) translate(var(--tx, 0px), var(--ty, 0px));
      opacity: 1;
    }
  }
</style>

<style>
  :global(body.sheet-open) {
    overflow: hidden !important;
  }

  .letter-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(30, 22, 12, 0.4);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    z-index: 500;
    opacity: 0;
  }

  .letter-sheet {
    display: none;
    position: fixed;
    flex-direction: column;
    background: linear-gradient(175deg, #faf6ee 0%, #f5efe3 100%);
    box-shadow:
      0 -8px 40px rgba(40, 28, 12, 0.18),
      0 -2px 12px rgba(40, 28, 12, 0.08);
    z-index: 502;
    overflow: hidden;
  }

  .sheet-close {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 30px;
    height: 30px;
    border: none;
    background: rgba(60, 50, 38, 0.07);
    border-radius: 50%;
    color: #6b5e4e;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    z-index: 2;
  }

  .sheet-close:hover {
    background: rgba(60, 50, 38, 0.14);
  }

  .sheet-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 28px 32px 48px;
    opacity: 0;
  }

  .sheet-from-label {
    font-family: "Cormorant Garamond", serif;
    font-style: italic;
    font-size: 0.95rem;
    color: #b0a48c;
    margin: 0 0 2px;
  }

  .sheet-sender {
    font-family: "Cormorant Garamond", serif;
    font-size: 2rem;
    font-weight: 700;
    color: #3a3226;
    margin: 0 0 14px;
    letter-spacing: 0.01em;
  }

  .sheet-rule {
    border: none;
    height: 1.5px;
    background: linear-gradient(to right, #c9b896, transparent);
    width: 56px;
    margin: 0 0 24px;
  }

  .sheet-body {
    font-size: 1.35rem;
    line-height: 1.75;
    color: #4a3f33;
  }

  .sheet-body :global(p) {
    margin: 0 0 16px;
  }

  .sheet-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 16px 0;
    display: block;
  }

  /* Two images with no blank line between them in markdown → side by side */
  .sheet-body :global(p:has(img + img)) {
    display: flex;
    gap: 8px;
    margin: 16px 0;
  }
  .sheet-body :global(p:has(img + img) img) {
    flex: 1;
    width: 0;
    min-width: 0;
    margin: 0;
    object-fit: cover;
  }

  .sheet-body :global(strong) {
    font-weight: 700;
  }

  .sheet-body :global(em) {
    font-style: italic;
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>KJ, Happy Birthday!</title>
  </head>
  <body>
    <canvas id="dot-grid"></canvas>

    <main id="screen-1" class="relative z-10 flex items-center justify-center min-h-screen px-8 py-16">
      <div class="flex flex-col items-center gap-10 max-w-3xl w-full">
        <div class="flex flex-col md:flex-row gap-12 md:gap-16 items-center w-full">
          <!-- Polaroid -->
          <div class="flex-1 flex justify-center" style="perspective: 800px;">
            <div id="polaroid-entrance">
            <div
              id="polaroid"
