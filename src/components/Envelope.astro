---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  stamp: ImageMetadata;
  kjStamp?: 1 | 2;
  rotation?: number;
  offsetX?: number;
  offsetY?: number;
  slug?: string;
}

const {
  name,
  stamp,
  kjStamp = 1,
  rotation = 0,
  offsetX = 0,
  offsetY = 0,
  slug = '',
} = Astro.props;
---

<button
  class="envelope"
  type="button"
  data-sender={name}
  data-slug={slug}
  style={`--r:${rotation}deg; --tx:${offsetX}px; --ty:${offsetY}px;`}
>
  <div class="stamp-area">
    <div class="stamp">
      <Image src={stamp} alt="" />
    </div>
  </div>

  <img class="address-lines" src="/images/kj-address-lines.svg" alt="" />

  <div class="address">
    <span class="from-label">from</span>
    <span class="sender">{name}</span>
  </div>

  <img class="kj-stamp" src={`/images/kj-stamp-${kjStamp}.svg`} alt="" />
</button>

<style>
  .envelope {
    position: relative;
    width: 400px;
    aspect-ratio: 1.45;
    background: #f2e8d0;
    border: none;
    border-radius: 8px;
    box-shadow:
      inset 0 1px 0 0 #faf4e8,
      0 2px 8px rgba(60, 40, 20, 0.1),
      0 1px 3px rgba(60, 40, 20, 0.08);
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-family: inherit;
    text-align: center;
    z-index: 1;
    transform: rotate(var(--r, 0deg)) translate(var(--tx, 0px), var(--ty, 0px));
    transition:
      transform 0.35s cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 0.3s ease;
    outline: none;
  }

  .envelope:hover {
    z-index: 10;
    transform: rotate(0deg) translateY(-8px) scale(1.04);
    box-shadow:
      inset 0 1px 0 0 #faf4e8,
      0 16px 32px rgba(60, 40, 20, 0.16),
      0 4px 10px rgba(60, 40, 20, 0.08);
  }

  .envelope:focus-visible {
    box-shadow:
      0 0 0 3px #5a189a55,
      0 2px 8px rgba(60, 40, 20, 0.1);
  }

  /* stamp ------------------------------------------------------------ */

  .stamp-area {
    position: absolute;
    left: 20px;
    top: 20px;
  }

  .stamp {
    width: 154px;
    height: 184px;
    background: url("/images/kj-stamp-bg.svg") center / contain no-repeat;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .stamp img {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 1px;
    object-fit: cover;
  }

  /* address lines ---------------------------------------------------- */

  .address-lines {
    position: absolute;
    right: 20px;
    bottom: 126px;
    width: 42%;
    height: auto;
    pointer-events: none;
  }

  /* address area ----------------------------------------------------- */

  .address {
    position: absolute;
    bottom: 16px;
    right: 20px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .from-label {
    font-family: "Cormorant Garamond", serif;
    font-style: italic;
    font-size: 1rem;
    font-weight: 400;
    color: #b0a48c;
    letter-spacing: 0.02em;
    line-height: 0.3;
    margin-bottom: -2px;
  }

  .sender {
    font-family: "Cormorant Garamond", serif;
    font-size: 1.6rem;
    font-weight: 600;
    color: #3a3226;
    letter-spacing: 0.01em;
  }

  /* kj stamp --------------------------------------------------------- */

  .kj-stamp {
    position: absolute;
    top: 157px;
    left: 137px;
    width: 85px;
    height: auto;
    opacity: 0.85;
    pointer-events: none;
    z-index: 2;
  }

  @media (max-width: 480px) {
    .envelope {
      width: 340px;
    }

    .stamp-area {
      left: 16px;
      top: 16px;
    }

    .stamp {
      width: 131px;
      height: 156px;
      padding: 14px 17px;
    }

    .address-lines {
      right: 16px;
      bottom: 107px;
    }

    .address {
      bottom: 14px;
      right: 16px;
    }

    .from-label {
      font-size: 0.9rem;
    }

    .sender {
      font-size: 1.4rem;
    }

    .kj-stamp {
      top: 133px;
      left: 116px;
      width: 72px;
    }
  }
</style>
